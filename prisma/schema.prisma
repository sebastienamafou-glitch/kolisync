generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum Role {
  ADMIN
  OWNER
  DISPATCHER
  DRIVER
}

enum KycStatus {
  UNVERIFIED
  PENDING
  APPROVED
  REJECTED
}

enum PackageStatus {
  PENDING
  DISPATCHED
  AVAILABLE_PUBLIC
  IN_TRANSIT
  DELIVERED_VERIFIED
  DELIVERED_UNSECURED
  FAILED_RETURNED
  CONFLICT
}

enum CashStatus {
  UNCOLLECTED
  HELD_BY_DRIVER
  RECONCILED_WITH_SELLER
  SETTLED_DIRECTLY_TO_MERCHANT
}

enum SocialTransactionType {
  CONTRIBUTION 
  PAYOUT       
  ADJUSTMENT   
}

// --- MODÈLES ---

model Tenant {
  id                 String         @id @default(cuid())
  name               String
  isPro              Boolean        @default(false)
  subscriptionEndsAt DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  users              User[]
  orders             Order[]
  packageEvents      PackageEvent[]
}

model User {
  id                String         @id @default(cuid())
  tenantId          String
  email             String?        @unique
  phone             String         @unique
  name              String
  pinCode           String         
  role              Role           @default(DRIVER)
  preferredCommune  String?
  maxCashLimit      Float          @default(50000)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  driverOrders      Order[]        @relation("DriverOrders")
  packageEvents     PackageEvent[] @relation("UserEvents")
  
  socialWallet      SocialWallet?
  disputes          Dispute[]      @relation("DriverDisputes")
  pushSubscriptions  PushSubscription[] 
  // --- MODULE KYC : Identité ---
  kycStatus         KycStatus      @default(UNVERIFIED)
  idDocumentUrl     String?        // CNI / Passeport
  selfieUrl         String?        // Photo de vérification
  kycRejectionReason String?       // Raison en cas de refus
  kycSubmittedAt    DateTime?
  kycVerifiedAt     DateTime?

  // --- MODULE KYC : Conformité Routière & Sécurité (Pour les DRIVER) ---
  licensePlate           String?   // Plaque d'immatriculation
  vehicleRegistrationUrl String?   // Photo de la carte grise
  drivingLicenseUrl      String?   // Photo du permis de conduire
  emergencyContact       String?   // Ex: "Mère: 0700000000"
}

model Order {
  id                 String         @id @default(cuid())
  tenantId           String
  isPublic           Boolean        @default(false)
  driverId           String?
  customerName       String
  customerPhone      String
  deliveryAddress    String?
  commune            String?
  latitude           Float?
  longitude          Float?
  packageStatus      PackageStatus  @default(PENDING)
  cashStatus         CashStatus     @default(UNCOLLECTED)
  
  amountDue          Float         
  deliveryFee        Float          @default(0)
  depositAmount      Float          @default(0)
  socialContribution Float          @default(0) 
  securityPin        String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  driver             User?          @relation("DriverOrders", fields: [driverId], references: [id])
  events             PackageEvent[] 
  socialTransactions SocialTransaction[]
  dispute            Dispute?
  
  pickupAddress      String         
  pickupLat          Float?
  pickupLng          Float?
}

// --- MODÈLES SOCIAUX ---

model SocialWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0) 
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions SocialTransaction[]
}

model SocialTransaction {
  id        String                @id @default(cuid())
  walletId  String
  orderId   String?
  amount    Float
  type      SocialTransactionType @default(CONTRIBUTION)
  createdAt DateTime              @default(now())

  wallet    SocialWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  order     Order?                @relation(fields: [orderId], references: [id])
}

// --- MODÈLES DE LOGISTIQUE ET RISQUE ---

model PackageEvent {
  id          String         @id @default(cuid())
  tenantId    String
  orderId     String
  authorId    String
  fromStatus  PackageStatus?
  toStatus    PackageStatus
  logicalTs   Int            
  latitude    Float?
  longitude   Float?
  reason      String?
  createdAt   DateTime       @default(now())

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author      User           @relation("UserEvents", fields: [authorId], references: [id])
}

model CustomerRisk {
  id              String         @id @default(cuid())
  customerPhone   String         @unique
  reportCount     Int            @default(0)
  lastIncidentAt  DateTime       @default(now())
  incidents       IncidentLog[]
}

model IncidentLog {
  id              String       @id @default(cuid())
  riskProfileId   String
  tenantId        String      
  reason          String       
  createdAt       DateTime     @default(now())
  
  riskProfile     CustomerRisk @relation(fields: [riskProfileId], references: [id])
}

model Dispute {
  id              String   @id @default(cuid())
  orderId         String   @unique
  driverId        String
  reason          String   
  driverComment   String?
  latitude        Float?
  longitude       Float?
  createdAt       DateTime @default(now())

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver User  @relation("DriverDisputes", fields: [driverId], references: [id])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
